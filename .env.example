# ═══════════════════════════════════════════════════════════════════════════════
# IST Markets NewsBot — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed to source control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY. Never add a VITE_ prefix — this key must never reach the browser.
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── Firebase Frontend ─────────────────────────────────────────────────────────
# VITE_* variables are embedded in the browser bundle at build time.
# The Firebase API key is safe to expose (security relies on Firebase Rules).
# Restrict it to your domain in Google Cloud Console → APIs & Services → Credentials.
# Get all values from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxx"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_FIREBASE_DATABASE_ID="(default)"

# ── Firebase Backend ──────────────────────────────────────────────────────────
# Used by server.ts for Firestore REST API calls (same values as above).
FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_DATABASE_ID="(default)"

# ── App URL ───────────────────────────────────────────────────────────────────
# The public URL where this app is hosted (used for temp image URLs sent to Metricool).
APP_URL="https://publisher.istmarkets.com"

# ── Financial Modeling Prep ───────────────────────────────────────────────────
# Get from: https://financialmodelingprep.com/developer/docs
FMP_API_KEY="YOUR_FMP_API_KEY"

# ── Metricool ─────────────────────────────────────────────────────────────────
# Get from: Metricool account settings → API
METRICOOL_USER_TOKEN="YOUR_METRICOOL_TOKEN"
METRICOOL_USER_ID="YOUR_METRICOOL_USER_ID"
